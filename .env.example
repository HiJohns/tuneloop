# ============================================================
# TuneLoop 预生产环境配置模板
# 实际使用时请修改密码/密钥为真实值
# ============================================================

# 1. 数据库
DB_HOST=localhost
DB_PORT=5432
TUNELOOP_DB=tuneloop_db            # 预生产用 tuneloop_db，开发用 tuneloop_debug
POSTGRES_USER=tuneloop_user
POSTGRES_PASSWORD=tune_secret_2026

# 2. 服务端口 (对应 NGINX 反向代理)
TUNELOOP_WWW_PORT=5558
TUNELOOP_WX_PORT=5559

# 3. 前端 API 端点 (构建时注入)
API_PC=https://web.cadenzayueqi.com
API_WX=https://wx.cadenzayueqi.com

# 4. Beacon IAM
BEACONIAM_EXTERNAL_URL=https://iam.cadenzayueqi.com
BEACONIAM_INTERNAL_URL=http://localhost:5560

# 5. IAM Namespace 鉴权 (用于自动注册 OAuth 应用和管理员创建)
# IAM_NAMESPACE 既是 namespace 标识也是 IAMClient 的 client_id
# IAM_SECRET 是 namespace 的 client_secret，用于 X-Namespace-Secret 鉴权
IAM_NAMESPACE=tuneloop
IAM_SECRET=<namespace-secret-from-iam>

# 6. 冷启动管理员 (首次部署时自动创建)
# BootstrapIAM 检测 users 表为空时，调用 IAM 创建此邮箱的管理员账户
# IAM 随机生成密码并通过邮件发送
# 未配置则冷启动时报错退出
ADMIN_EMAIL=admin@tuneloop.com
