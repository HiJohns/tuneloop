# TuneLoop Backend Service Configuration
# Generated: 2026-03-22

# PostgreSQL Database (Standard Docker Variables)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tuneloop
POSTGRES_PASSWORD=your_password
TUNELOOP_DB=tuneloop
DB_SSLMODE=disable

# Beacon IAM Configuration
# External URL: Used for frontend OIDC redirects
BEACONIAM_EXTERNAL_URL=https://iam.example.com
# Internal URL: Used for backend API calls (higher performance)
BEACONIAM_INTERNAL_URL=http://localhost:8080
IAM_CLIENT_ID=tuneloop
IAM_CLIENT_SECRET=your_iam_secret

# IAM Bootstrap (Development Only)
# If set, automatically creates IAM Client on startup if missing
# BOOTSTRAP_CLIENT_ID=tuneloop
# BOOTSTRAP_CLIENT_SECRET=your_bootstrap_secret
# BOOTSTRAP_REDIRECT_URIS=http://localhost:5554/callback,http://localhost:5553/callback

# Service URLs
# Used to extract port for ListenAndServe binding
TUNELOOP_WWW_URL=http://localhost:5554
TUNELOOP_WX_URL=http://localhost:5553

# Optional: GIN Mode
GIN_MODE=release
