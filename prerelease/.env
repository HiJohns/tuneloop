# 1. 数据库配置 (从根目录 .env 复制)
TUNELOOP_DB=tuneloop_db
POSTGRES_USER=tuneloop_user
POSTGRES_PASSWORD=tune_secret_2026

# 2. 预发布环境端口 (对应 NGINX 转发)
TUNELOOP_WWW_PORT=5558
TUNELOOP_WX_PORT=5559

# 3. 预发布 IAM 配置 (必须指向正式域名)
IAM_PC_CLIENT_ID=tuneloop-pc
IAM_PC_REDIRECT_URI=https://web.cadenzayueqi.com/callback

IAM_WX_CLIENT_ID=tuneloop-wx_wechat_1776711596
IAM_WX_CLIENT_SECRET=WQOwNXoTqXrHhh_fxyaJolT-v9beRCld
IAM_WX_REDIRECT_URI=https://wx.cadenzayueqi.com/callback

# 4. API Endpoints (for frontend builds)
API_PC=https://web.cadenzayueqi.com
API_WX=https://wx.cadenzayueqi.com

# 5. Beacon IAM 外部 URL
BEACONIAM_EXTERNAL_URL=https://iam.cadenzayueqi.com

# 6. IAM Backend Credentials (for token exchange)
